# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit it.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore bikehorn.jks -alias bikehorn \
#     -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=../../bikehorn.jks
storePassword=your_keystore_password
keyAlias=bikehorn
keyPassword=your_key_password
